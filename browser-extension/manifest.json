{
  "manifest_version": 3,
  "name": "SecureLink",
  "version": "1.1.0",
  "description": "Automatically scans URLs you visit and warns you about potentially malicious sites. Sign in for more scans!",
  "permissions": [
    "tabs",
    "webNavigation",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["warning.html", "warning.js", "warning.css", "upgrade.html", "upgrade.js", "upgrade.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
