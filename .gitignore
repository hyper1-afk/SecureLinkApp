# ============================================================
# SecureLinkApp - Git Ignore
# ============================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/
.venv/
ENV/

# Environment variables - NEVER COMMIT!
.env
.env.local
.env.production

# Database
*.db
*.sqlite
*.sqlite3

# Logs
*.log
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
desktop.ini

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Temporary files
tmp/
temp/
*.tmp
*.bak

# Secrets & Keys (extra protection)
*.pem
*.key
secrets.json
credentials.json

# Node (if any frontend build)
node_modules/

# Deployment artifacts
.vercel/
.netlify/
.vercel
