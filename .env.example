# ============================================================
# SecureLinkApp - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ===================
# FLASK SETTINGS
# ===================
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False
FLASK_ENV=production

# Application URL (your deployed domain)
APP_URL=https://securelinkapp.com

# ===================
# DATABASE
# ===================
# For local development:
DATABASE_PATH=link_verifier.db

# For production (PostgreSQL) - Use this format:
# DATABASE_URL=postgresql://user:password@host:5432/database_name
DATABASE_URL=

# ===================
# STRIPE PAYMENTS
# ===================
# Get your keys at: https://dashboard.stripe.com/apikeys
# Use TEST keys for development, LIVE keys for production

# Test Keys (for development)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Live Keys (for production)
STRIPE_SECRET_KEY=sk_live_your_live_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_live_publishable_key

# Webhook Secret - Get from Stripe Dashboard > Webhooks
# Required for processing subscription events
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create products in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID=price_xxx
STRIPE_PRO_YEARLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=price_xxx

# ===================
# OAUTH / SOCIAL LOGIN
# ===================
# Google OAuth
# Get credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth (optional)
# Get credentials at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Yahoo OAuth (optional)
# Get credentials at: https://developer.yahoo.com/apps/
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=

# ===================
# EMAIL MONITORING (IMAP)
# ===================
# For Gmail, use an App Password: https://support.google.com/accounts/answer/185833
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_USE_SSL=True
EMAIL_CHECK_INTERVAL=60

# ===================
# SECURITY APIS (Optional but Recommended)
# ===================
# VirusTotal API - Get free key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# Google Safe Browsing API - Get at: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=AIzaSyCTI0vzGLFgkZKR3NShFU_u0p_XZUivfpw

# ===================
# THREAT INTELLIGENCE APIS
# ===================
# AbuseIPDB - Get free API key at: https://www.abuseipdb.com/account/api
# Free tier: 1,000 checks/day - Used for real-time threat map
ABUSEIPDB_API_KEY=

# URLhaus (abuse.ch) - No API key needed, free to use

# ===================
# NOTIFICATION SETTINGS
# ===================
ENABLE_DESKTOP_NOTIFICATIONS=False
ENABLE_EMAIL_NOTIFICATIONS=True
NOTIFICATION_EMAIL=alerts@securelinkapp.com

# SMTP for sending emails (notifications, reports)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=True

# ===================
# RISK THRESHOLDS
# ===================
HIGH_RISK_THRESHOLD=0.7
MEDIUM_RISK_THRESHOLD=0.4

# ===================
# URL ANALYSIS SETTINGS
# ===================
ENABLE_DNS_CHECK=True
ENABLE_WHOIS_CHECK=True
ENABLE_SSL_CHECK=True
REQUEST_TIMEOUT=10

# ===================
# LOGGING
# ===================
LOG_LEVEL=INFO
LOG_FILE=link_verifier.log

# ===================
# RATE LIMITING (Production)
# ===================
RATELIMIT_STORAGE_URL=memory://
# For production with Redis:
# RATELIMIT_STORAGE_URL=redis://localhost:6379
