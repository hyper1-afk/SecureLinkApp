# SecureLink — Docker Environment Variables
# ============================================================
# Copy this file to .env before running docker compose up -d
#   cp .env.docker.example .env
#
# Lines marked REQUIRED must be set before the app will start.
# All other lines are optional — leave blank to disable that feature.
# ============================================================


# ============================================================
# REQUIRED
# ============================================================

# Flask secret key — CHANGE THIS. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Admin operations key — CHANGE THIS. Use a different value from SECRET_KEY.
ADMIN_SECRET_KEY=

# Fernet encryption key for sensitive stored data — generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_ENCRYPTION_KEY=

# Your public URL (used in emails, OAuth redirects, extension links)
APP_URL=https://yourdomain.com

# Display name shown in the UI and emails (customize for your org)
APP_NAME=SecureLink

# License key for self-hosted instances — get yours at securelinkapp.com/account
# Required to unlock Pro/Enterprise features for users on your self-hosted instance.
# Leave blank to run the free-tier core platform only.
LICENSE_KEY=


# ============================================================
# DATABASE (PostgreSQL — used by docker-compose)
# ============================================================

POSTGRES_USER=securelink
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=securelink

# Override the full connection string if you use an external database:
# DATABASE_URL=postgresql://user:password@host:5432/dbname


# ============================================================
# STRIPE PAYMENTS
# Optional — leave blank to run in free-only mode (no paid tiers)
# Get keys at: https://dashboard.stripe.com/apikeys
# ============================================================

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs from your Stripe Dashboard (Products → Prices)
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID=
STRIPE_ENTERPRISE_YEARLY_PRICE_ID=


# ============================================================
# GOOGLE OAUTH
# Optional — for "Sign in with Google"
# Get credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/auth/google/callback
# ============================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ============================================================
# EXTERNAL SCANNING APIs
# Optional — the scanner works without these but detection improves with them
# ============================================================

# VirusTotal (free tier: 4 lookups/min, 500/day)
# Get key at: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=

# Google Safe Browsing (free, generous quota)
# Get key at: https://developers.google.com/safe-browsing/v4/get-started
GOOGLE_SAFE_BROWSING_API_KEY=

# Have I Been Pwned — required for email breach checking
# Paid API key at: https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# NewsAPI — for the security news feed
# Free tier at: https://newsapi.org/register
NEWS_API_KEY=


# ============================================================
# SMTP — Outgoing email (password resets, alerts, weekly reports)
# Optional but strongly recommended for production
# Works with any SMTP provider: Resend, AWS SES, SendGrid, Gmail, etc.
# ============================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Where to receive internal alert/notification emails
SUPPORT_EMAIL=


# ============================================================
# SUPPORT INBOX
# Optional — auto-creates support tickets from inbound emails
# ============================================================

SUPPORT_EMAIL_ADDRESS=
SUPPORT_EMAIL_PASSWORD=
SUPPORT_IMAP_HOST=imap.gmail.com
SUPPORT_IMAP_PORT=993
SUPPORT_IMAP_SSL=True
SUPPORT_EMAIL_CHECK_INTERVAL=60


# ============================================================
# FLASK / SERVER SETTINGS
# ============================================================

FLASK_ENV=production
DEBUG=false
PORT=5000
LOG_LEVEL=INFO
