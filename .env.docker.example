# SecureLinkApp - Docker Environment Variables
# Copy this file to .env and fill in your values
# Run: cp .env.docker.example .env

# ===========================================
# REQUIRED SETTINGS
# ===========================================

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Application URL (your domain or IP)
APP_URL=http://localhost:5000

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================

POSTGRES_USER=securelink
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=securelink

# ===========================================
# STRIPE PAYMENTS (Required for paid features)
# ===========================================

STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================================
# GOOGLE OAUTH (Optional - for social login)
# ===========================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# API KEYS (Optional - for enhanced scanning)
# ===========================================

VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=

# ===========================================
# EMAIL / SMTP (Optional - for notifications)
# ===========================================

SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_USE_SSL=True
SMTP_USERNAME=support@securelinkapp.com
SMTP_PASSWORD=

# Email to receive support ticket notifications
SUPPORT_EMAIL=admin@securelinkapp.com

# ===========================================
# SUPPORT INBOX (Auto-create tickets from emails)
# ===========================================

# The support email address customers will email
SUPPORT_EMAIL_ADDRESS=support@securelinkapp.com
SUPPORT_EMAIL_PASSWORD=

# IMAP settings (GoDaddy defaults shown)
SUPPORT_IMAP_HOST=imap.secureserver.net
SUPPORT_IMAP_PORT=993
SUPPORT_IMAP_SSL=True

# How often to check for new emails (seconds)
SUPPORT_EMAIL_CHECK_INTERVAL=60

# ===========================================
# FLASK SETTINGS
# ===========================================

FLASK_ENV=production
DEBUG=false
PORT=5000
